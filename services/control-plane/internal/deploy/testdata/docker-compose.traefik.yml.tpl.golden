services:
  traefik:
    image: docker.io/library/traefik:v3.7.7
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /opt/labprovider/runtime/traefik/traefik.yml:/etc/traefik/traefik.yml:ro
      - /opt/labprovider/runtime/traefik/dynamic:/etc/traefik/dynamic:ro
      - /opt/labprovider/runtime/traefik/usersfile:/usersfile:ro
      - /opt/labprovider/traefik/certs:/certs:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - proxy

networks:
  proxy:
    external: true
