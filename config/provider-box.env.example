# Host and domain settings
# HOST_IP is the host address in CIDR notation; SEARCH_DOMAIN is the lab DNS zone.
HOST_IP="192.168.12.121/24"
SEARCH_DOMAIN="sddc.lab"

# Built-in service FQDNs. All resolve to HOST_IP; DNS records for them are
# generated automatically by the selected DNS backend (never add them to
# config/dns.seed). PROVIDER_BOX_FQDN is the
# canonical host identity and the reverse PTR target for HOST_IP.
PROVIDER_BOX_FQDN="provider-box.sddc.lab"
DNS_FQDN="dns.sddc.lab"
CA_FQDN="ca.sddc.lab"
DEPOT_FQDN="vcfdepot.sddc.lab"
KEYCLOAK_FQDN="auth.sddc.lab"
AUTHENTIK_FQDN="idp.sddc.lab"
NETBOX_FQDN="netbox.sddc.lab"
S3_FQDN="s3.sddc.lab"
SFTP_FQDN="sftp.sddc.lab"
SYSLOG_FQDN="syslog.sddc.lab"

# Internal networks allowed to query DNS and NTP
ALLOW_NET_1="10.0.0.0/8"
ALLOW_NET_2="172.16.0.0/12"
ALLOW_NET_3="192.168.0.0/16"

# Upstream DNS and NTP providers
# DNS_FORWARDER is the upstream resolver Technitium uses for external resolution.
DNS_FORWARDER="8.8.8.8"

CHRONY_SERVER_1="0.se.pool.ntp.org"
CHRONY_SERVER_2="1.se.pool.ntp.org"
CHRONY_SERVER_3="2.se.pool.ntp.org"

# Container images (pinned versions)
# This is the central place to control pinned image versions for containerized services.
# Update versions here without editing templates or bootstrap logic.
AUTHENTIK_IMAGE="ghcr.io/goauthentik/server:2026.5.3"
AUTHENTIK_POSTGRES_IMAGE="docker.io/library/postgres:16-alpine"
CA_IMAGE="docker.io/smallstep/step-ca:0.30.2"
# Dedicated postgres for step-ca ONLY (module independence; NOT shared).
CA_POSTGRES_IMAGE="docker.io/library/postgres:17-alpine"
DEPOT_IMAGE="docker.io/library/nginx:1.31-alpine"
KEYCLOAK_IMAGE="quay.io/keycloak/keycloak:26.6.3"
NETBOX_IMAGE="docker.io/netboxcommunity/netbox:v4.6.2"
NETBOX_POSTGRES_IMAGE="docker.io/library/postgres:17-alpine"
NETBOX_REDIS_IMAGE="docker.io/library/redis:7-alpine"
NETBOX_NGINX_IMAGE="docker.io/library/nginx:1.31-alpine"
S3_IMAGE="docker.io/chrislusf/seaweedfs:4.31"
SFTPGO_IMAGE="docker.io/drakkan/sftpgo:v2.7.3"
TECHNITIUM_IMAGE="docker.io/technitium/dns-server:15.3.0"
# Locally built by the control plane deploy engine from embedded Dockerfiles
# (alpine + chrony / alpine + rsyslog); no registry access needed.
CHRONY_IMAGE="provider-box/chrony:0.1.0"
RSYSLOG_IMAGE="provider-box/rsyslog:0.1.0"

# Keycloak bootstrap credentials
KEYCLOAK_PORT="8443"
KEYCLOAK_ADMIN_USER="admin"
KEYCLOAK_ADMIN_PASSWORD="CHANGE_ME"
KEYCLOAK_BOOTSTRAP_REALM_NAME="provider-box"
KEYCLOAK_BOOTSTRAP_GROUP_NAME="vcf-admins"
KEYCLOAK_BOOTSTRAP_USERNAME="lab-admin"
KEYCLOAK_BOOTSTRAP_USER_PASSWORD="CHANGE_ME"
KEYCLOAK_BOOTSTRAP_USER_EMAIL_DOMAIN="sddc.lab"
KEYCLOAK_BOOTSTRAP_CLIENT_ID="vcf-sso"
KEYCLOAK_BOOTSTRAP_CLIENT_SECRET="CHANGE_ME"
# Comma-separated HTTPS redirect URIs for the bootstrap OIDC client. Do not include spaces between entries.
KEYCLOAK_BOOTSTRAP_CLIENT_REDIRECT_URIS="https://pod-240-vc01.sddc.lab/federation/t/CUSTOMER/auth/response/oauth2"

# Authentik identity provider (OIDC + outbound SCIM 2.0)
AUTHENTIK_PORT="9443"
AUTHENTIK_ADMIN_PASSWORD="CHANGE_ME"
AUTHENTIK_API_TOKEN="CHANGE_ME"
# Must be changed. Authentik requires a strong secret key of at least 50 characters.
AUTHENTIK_SECRET_KEY="CHANGE_ME_WITH_AT_LEAST_50_RANDOM_CHARACTERS_BEFORE_USE"
AUTHENTIK_PG_DB="authentik"
AUTHENTIK_PG_USER="authentik"
AUTHENTIK_PG_PASSWORD="CHANGE_ME"
AUTHENTIK_BOOTSTRAP_CLIENT_ID="vcf-sso"
AUTHENTIK_BOOTSTRAP_CLIENT_SECRET="CHANGE_ME"
AUTHENTIK_BOOTSTRAP_GROUP_NAME="vcf-admins"
AUTHENTIK_BOOTSTRAP_USERNAME="lab-admin"
AUTHENTIK_BOOTSTRAP_USER_PASSWORD="CHANGE_ME"
AUTHENTIK_BOOTSTRAP_USER_EMAIL_DOMAIN="sddc.lab"
# Comma-separated HTTPS redirect URIs for the bootstrap OIDC client. Do not include spaces between entries.
AUTHENTIK_BOOTSTRAP_CLIENT_REDIRECT_URIS="https://pod-240-vc01.sddc.lab/federation/t/CUSTOMER/auth/response/oauth2"

# NetBox source of truth
NETBOX_PORT="8444"
NETBOX_POSTGRES_DB="netbox"
NETBOX_POSTGRES_USER="netbox"
NETBOX_POSTGRES_PASSWORD="CHANGE_ME"
NETBOX_REDIS_PASSWORD="CHANGE_ME"
# Must be changed. NetBox requires a strong secret key of at least 50 characters.
NETBOX_SECRET_KEY="CHANGE_ME_WITH_AT_LEAST_50_RANDOM_CHARACTERS_BEFORE_USE"
# Optional. NetBox 4.6 requires an API token pepper (>= 50 chars) to hash v2 API
# tokens. Leave unset to generate and persist one automatically under
# NETBOX_DIR/secrets. Do not change it once tokens exist: changing the pepper
# invalidates every existing API token, including the dns-sync token.
# NETBOX_API_TOKEN_PEPPER=""
NETBOX_ALLOWED_HOSTS="netbox.sddc.lab"
NETBOX_CSRF_TRUSTED_ORIGINS="https://netbox.sddc.lab:8444 https://netbox.sddc.lab"
NETBOX_SUPERUSER_NAME="admin"
NETBOX_SUPERUSER_EMAIL="admin@sddc.lab"
NETBOX_SUPERUSER_PASSWORD="CHANGE_ME"

# S3-compatible object storage
S3_PORT="8333"
S3_ACCESS_KEY="CHANGE_ME"
S3_SECRET_KEY="CHANGE_ME"

# VCF offline depot
DEPOT_HTTP_PORT="80"
DEPOT_HTTPS_PORT="443"
DEPOT_BASIC_AUTH_USER="depot"
DEPOT_BASIC_AUTH_PASSWORD="CHANGE_ME"

# SFTPGo service
SFTP_PORT="2022"
SFTP_ADMIN_PORT="8080"
SFTP_ADMIN_USER="admin"
SFTP_ADMIN_PASSWORD="CHANGE_ME"
# Optional. Set all three values to bootstrap one SFTPGo backup user if it does not already exist.
# SFTP_BACKUP_USERNAME="backup"
# SFTP_BACKUP_PASSWORD="CHANGE_ME"
# SFTP_BACKUP_HOME_DIR="/opt/provider-box/sftpgo/data/backup"

# Technitium DNS service
# Web console (HTTP) and TLS console/API ports. DNS itself is fixed on 53/tcp+udp.
TECHNITIUM_HTTP_PORT="5380"
TECHNITIUM_HTTPS_PORT="53443"
# The control plane rotates the first-boot admin/admin credentials to this
# value on first deploy and authenticates with it on re-runs.
TECHNITIUM_ADMIN_PASSWORD="CHANGE_ME"
# dns-sync (NetBox -> Technitium reconcile)
# Locally built image tag (Dockerfile under services/dns-sync). Bootstrap
# builds this tag, then compose runs it - no registry push needed.
DNS_SYNC_IMAGE="provider-box/dns-sync:0.1.0"
# HTTPS endpoints dns-sync reads from / writes to; the FQDNs are pinned to
# 127.0.0.1 during bootstrap (single-node design).
DNS_SYNC_NETBOX_URL="https://netbox.sddc.lab:8444"
DNS_SYNC_TECHNITIUM_URL="https://dns.sddc.lab:53443"
# Reconcile interval, e.g. 30s, 5m, or 1h.
DNS_SYNC_INTERVAL="30s"
# Non-admin Technitium user the read-only dashboard authenticates as (auto-created
# by --technitium). dns-sync grants it View on each newly created zone so
# continuously-synced zones appear in the dashboard without a --technitium re-run.
# Best-effort; leave empty to disable the grant.
DNS_SYNC_TECHNITIUM_DASHBOARD_USER="dashboard"

# rsyslog collector
SYSLOG_PORT="514"

# Provider Box control plane (services/control-plane) - currently the read-only
# "current state" dashboard. Deploy with `--dashboard` (also included in
# `--all`, last), or run it manually with services/control-plane/scripts/run.sh.
# See services/control-plane/README.md.
# Locally built image tag (Dockerfile under services/control-plane); compose
# builds it. The scoped read-only tokens under CONTROL_PLANE_SECRETS_DIR are
# auto-provisioned by --netbox and --technitium; until the producing module has
# run the NetBox and Technitium panels degrade to "not configured" rather than
# failing.
CONTROL_PLANE_IMAGE="provider-box/control-plane:0.1.0"
CONTROL_PLANE_FQDN="dashboard.sddc.lab"
# Listen address for the control plane's own HTTPS listener (host networking).
CONTROL_PLANE_ADDR=":8445"
# Where the issued leaf cert (control-plane.crt/.key) lives, and the CA root
# the control plane trusts when calling NetBox/Technitium over TLS.
CONTROL_PLANE_CERT_DIR="/opt/provider-box/control-plane/certs"
# Read-only scoped tokens the control plane reads. Auto-provisioned at deploy
# time (--netbox and --technitium write them here when CONTROL_PLANE_SECRETS_DIR
# is set); an operator-placed SOPS/age token in the same path wins and is never
# overwritten:
#   technitium.token          - a scoped Technitium API token (not the admin one)
#   netbox-readonly.token     - a DEDICATED minimum-read-scope NetBox token,
#                               NOT the dns-sync or bootstrap admin token
CONTROL_PLANE_SECRETS_DIR="/opt/provider-box/control-plane/secrets"
# Days-to-expiry threshold below which a certificate is flagged as expiring.
CONTROL_PLANE_CERT_WARN_DAYS="30"
# HTTPS endpoints the control plane reads (pinned to 127.0.0.1 via extra_hosts,
# single-node design). Hosts are the FQDNs those URLs resolve to.
CONTROL_PLANE_NETBOX_URL="https://netbox.sddc.lab:8444"
CONTROL_PLANE_NETBOX_HOST="netbox.sddc.lab"
CONTROL_PLANE_TECHNITIUM_URL="https://dns.sddc.lab:53443"
CONTROL_PLANE_TECHNITIUM_HOST="dns.sddc.lab"
# Host docker group id, so the read-only socket mount is usable by uid 1000.
# Find it with: getent group docker | cut -d: -f3
CONTROL_PLANE_DOCKER_GID="999"
# Comma-separated container name substrings shown in the Services panel.
CONTROL_PLANE_CONTAINER_FILTERS="step-ca,technitium,netbox,dns-sync,authentik,keycloak,depot,sftpgo,seaweedfs,control-plane"
# Log lines tailed per container for the Recent errors panel.
CONTROL_PLANE_LOG_TAIL="200"
# Per-upstream request timeout; one slow source never hangs the page.
CONTROL_PLANE_UPSTREAM_TIMEOUT="5s"

# step-ca service
CA_PORT="9000"
CA_NAME="Provider Box CA"
CA_PROVISIONER_NAME="admin"
SERVICE_CERT_DURATION="8760h"
# Default managed step-ca password file location. Keep this under CA_DATA_DIR.
# Provider Box uses this file as-is when it already exists.
# Otherwise Provider Box materializes CA_PASSWORD here or generates one automatically.
CA_PASSWORD_FILE="/opt/provider-box/step-ca/secrets/password.txt"
# Optional. Provider Box writes this value to the managed password file with mode 0600 when set.
# CA_PASSWORD=""
CA_ENABLE_ACME="true"

# step-ca PostgreSQL backend (dedicated postgres, NOT shared with any other
# service). step-ca uses postgres as an opaque key-value store; switching to it
# is a CA rebuild - badger data does not migrate. The owner-role password is
# supplied to step-ca via a mounted .pgpass file (PGPASSFILE), never inlined in
# ca.json's dataSource. Mirrors the NETBOX_POSTGRES_* variables.
CA_POSTGRES_DB="stepca"
CA_POSTGRES_USER="stepca"
CA_POSTGRES_PASSWORD="CHANGE_ME"
# Loopback-published port for the CA postgres so the host-networked dashboard
# can read the cert tables at 127.0.0.1. Never exposed off-host.
CA_POSTGRES_PORT="5432"
# Read-only role the dashboard cert panel uses: SELECT on the cert tables only.
# Must differ from CA_POSTGRES_USER.
CA_POSTGRES_RO_USER="dashboard_ro"
CA_POSTGRES_RO_PASSWORD="CHANGE_ME"

# Output and deployment paths
# Working directory for rendered runtime files (separate from persistent data and repo location)
WORKDIR="/opt/provider-box/runtime"
CA_DATA_DIR="/opt/provider-box/step-ca"
# CA postgres data. MUST be a sibling of CA_DATA_DIR, never nested under it:
# do_ca runs `chown -R 1000:1000 CA_DATA_DIR`, which would corrupt postgres
# data (uid 70) on every redeploy if it lived inside CA_DATA_DIR.
CA_POSTGRES_DATA_DIR="/opt/provider-box/stepca-postgres"
DEPOT_DIR="/opt/provider-box/depot"
DEPOT_DATA_DIR="/opt/provider-box/depot/data"
DEPOT_CERT_DIR="/opt/provider-box/depot/certs"
DEPOT_AUTH_DIR="/opt/provider-box/depot/auth"
KEYCLOAK_DIR="/opt/provider-box/keycloak"
AUTHENTIK_DIR="/opt/provider-box/authentik"
NETBOX_DIR="/opt/provider-box/netbox"
NETBOX_MEDIA_DIR="/opt/provider-box/netbox/media"
NETBOX_POSTGRES_DATA_DIR="/opt/provider-box/netbox/postgres"
NETBOX_REDIS_DATA_DIR="/opt/provider-box/netbox/redis"
S3_DATA_DIR="/opt/provider-box/seaweedfs"
SFTP_DATA_DIR="/opt/provider-box/sftpgo/data"
SFTP_HOME_DIR="/opt/provider-box/sftpgo/home"
SFTP_CERT_DIR="/opt/provider-box/sftpgo/certs"
# Under /opt/provider-box so the containerized rsyslog and the control plane
# share the mount (previous default was /var/log/provider-box).
SYSLOG_LOG_DIR="/opt/provider-box/syslog/logs"
# Drift-file data for the containerized chrony.
CHRONY_DIR="/opt/provider-box/chrony"
TECHNITIUM_DATA_DIR="/opt/provider-box/technitium/data"
TECHNITIUM_CERT_DIR="/opt/provider-box/technitium/certs"
DNS_SYNC_DIR="/opt/provider-box/dns-sync"
# Where the dns-sync API tokens live. netbox.token is auto-provisioned by
# --netbox and technitium.token by --technitium; placing decrypted tokens
# here out of band (SOPS/age) is the operator override and wins while valid.
# --dns-sync fails if either token file is missing.
DNS_SYNC_SECRETS_DIR="/opt/provider-box/dns-sync/secrets"
